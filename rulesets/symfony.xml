<?xml version="1.0"?>
<ruleset name="SteevanB Symfony">
    <description>GroupUses configuration for Symfony namespaces</description>

    <rule ref="Steevanb.Uses.GroupUses">
        <properties>
            <property name="groupPrefixes" type="array">
                <!-- Bridge -->
                <element value="Symfony\Bridge\Doctrine"/>
