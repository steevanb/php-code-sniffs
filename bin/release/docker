#!/usr/bin/env bash

set -eu

if [ -z "${1:-}" ]; then
    echo -e "\e[41m Error: version parameter is required. \e[0m"
    echo "Usage: bin/release/docker <version> [--refresh] [--push]"
    exit 1
fi

readonly ROOT_PATH="$(realpath "$(dirname "$(realpath "$0")")/../..")"
source "${ROOT_PATH}"/bin/common.inc.sh

readonly VERSION="${1}"
shift

DOCKER_IMAGE_NAME="${RELEASE_DOCKER_IMAGE_NAME}:${VERSION}" \
    DOCKERFILE_PATH="${ROOT_PATH}"/docker/release \
    DOCKER_BUILD_EXTRA_ARGUMENTS="--build-arg VERSION=${VERSION}" \
    source "${ROOT_PATH}"/bin/docker-build.inc.bash "${@}"
