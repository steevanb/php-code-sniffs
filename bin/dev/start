#!/usr/bin/env bash

set -eu

readonly ROOT_PATH="$(realpath "$(dirname "$(realpath "$0")")/../..")"
source "${ROOT_PATH}"/bin/common.inc.sh

local=false
for param in "${@}"; do
    if [ "${param}" == "--local" ] || [ "${param}" == "-l" ]; then
        local=true
    fi
done

if ! ${local}; then
    docker pull "${CI_DOCKER_IMAGE_NAME}"
fi

"${ROOT_PATH}"/bin/composer update
