<?xml version="1.0"?>
<ruleset name="phpcs">
    <file>../../src</file>
    <file>../../tests</file>
    <rule ref="/app/src/Steevanb/ruleset.xml"/>
    <arg name="warning-severity" value="0"/>
    <arg name="cache" value="../../var/ci/phpcs/.phpcs.cache"/>
    <exclude-pattern>/vendor</exclude-pattern>
    <exclude-pattern>*/Fixtures/*</exclude-pattern>
    <arg name="report" value="Steevanb\PhpCodeSniffs\Reports\Steevanb"/>
    <rule ref="Steevanb.Uses.GroupUses">
        <properties>
            <property name="groupPrefixes" type="array">
                <element value="PHP_CodeSniffer"/>
                <element value="Steevanb\PhpCodeSniffs"/>
            </property>
        </properties>
    </rule>
</ruleset>
