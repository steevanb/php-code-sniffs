{
    "name": "steevanb/php-code-sniffs",
    "description": "Steevan BARBOYON coding standards.",
    "license": "MIT",
    "type": "library",
    "autoload": {
        "psr-4": {
            "Steevanb\\PhpCodeSniffs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Steevanb\\PhpCodeSniffs\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.4",
        "squizlabs/php_codesniffer": "4.0.*"
    },
    "scripts": {
        "post-install-cmd": [
            "@rm-composer-lock"
        ],
        "post-update-cmd": [
            "@rm-composer-lock"
        ],
        "rm-composer-lock": "rm composer.lock"
    },
    "require-dev": {
        "symfony/var-dumper": "^8.0",
        "phpunit/phpunit": "^12.0",
        "brianium/paratest": "^7.19"
    }
}
